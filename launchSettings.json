{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker: ContainrBot",
      "type": "docker",
      "request": "launch",
      "preLaunchTask": "docker-run: debug bot",
      "netCore": {
        "appProject": "${workspaceFolder}/ContainrBot/ContainrBot.csproj"
      },
      "env": {
        "ASPNETCORE_HTTP_PORTS": "8080",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "BOT_TOKEN": "MTQxMTE3NTc4OTE4MDc0Nzg1OA.GsKPLR.qn47ynah5IKAgyWGZ3980v9HjzZ-Nig_0kJF-o",
        "GAMESERVERAPI_BASEURL": "http://192.168.2.5:49280"
      },
      "serverReadyAction": {
        "action": "none"
      }
    },
    {
      "name": "Docker: ContainrBotApi",
      "type": "docker",
      "request": "launch",
      "preLaunchTask": "docker-run: debug api",
      "netCore": {
        "appProject": "${workspaceFolder}/ContainrBotApi/ContainrBotApi.csproj"
      },
      "env": {
        "ASPNETCORE_HTTP_PORTS": "8080",
        "ASPNETCORE_ENVIRONMENT": "Development",
        "GAME_SERVER_LIST": "[{\"FriendlyName\": \"valheim\", \"ContainerName\": \"valheim-valheim-crossplay-1\", \"Namespace\": \"valheim\"}, {\"FriendlyName\": \"cncnet\", \"ContainerName\": \"cncnet-server\", \"Namespace\": \"cncnet\"}, {\"FriendlyName\": \"satisfactory\", \"ContainerName\": \"satisfactory-server\", \"Namespace\": \"satisfactory\"}]"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}